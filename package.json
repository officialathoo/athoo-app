{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:push-force": "pnpm --filter @workspace/db run push-force",
    "db:seed": "pnpm --filter @workspace/scripts run seed",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "build:admin": "pnpm --filter @workspace/admin-panel run build",
    "start:api": "pnpm --filter @workspace/api-server run start",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:admin": "pnpm --filter @workspace/admin-panel run dev",
    "dev:mobile": "pnpm --filter @workspace/athoo-app run start",
    "lint": "pnpm -r --if-present run lint"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
