# ============================================================
# ATHOO Mobile App — Environment Variables
# Copy this file to .env and fill in the values below.
# All EXPO_PUBLIC_ vars are embedded at build time (visible in app bundle).
# NEVER put secrets in EXPO_PUBLIC_ variables.
# ============================================================

# ── API Connection ────────────────────────────────────────────
# Full URL of the API server (no trailing slash).
# On Replit: leave blank — auto-injected via EXPO_PUBLIC_DOMAIN
# Local dev:  http://localhost:8080
# Production: https://your-api.replit.app
EXPO_PUBLIC_API_BASE_URL=

# Replit proxy domain (auto-injected on Replit — leave blank locally)
EXPO_PUBLIC_DOMAIN=

# ── Expo Project ──────────────────────────────────────────────
# Get from: expo.dev → your project → settings → Project ID
# Get from: Replit → Secrets → EXPO_PUBLIC_PROJECT_ID (if stored)
EXPO_PUBLIC_PROJECT_ID=your-expo-project-uuid

# ── Google Maps ───────────────────────────────────────────────
# Enabled APIs: Maps SDK for Android, Maps SDK for iOS, Places API, Geocoding API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyAOVYRIgupAurZup5y1PRh8Ismb1A3lLao

# ── Push Notifications ────────────────────────────────────────
# Set to "true" to disable push notification registration in Expo Go
EXPO_PUBLIC_DISABLE_PUSH=false
