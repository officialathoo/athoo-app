# ============================================================
# ATHOO Admin Panel — Environment Variables
# Copy this file to .env and fill in values if needed.
# All VITE_ vars are embedded at build time (visible in browser).
# NEVER put secrets in VITE_ variables.
# ============================================================

# ── API Base URL ──────────────────────────────────────────────
# The admin panel auto-detects window.location.origin, so this is
# only needed when the admin panel is on a different domain than the API.
#
# Local dev (API on :8080, admin on :5173):
#   VITE_API_BASE_URL=http://localhost:8080
#
# Replit / same domain:
#   Leave blank — auto-detected
#
# Production (different domains):
#   VITE_API_BASE_URL=https://your-api.replit.app
VITE_API_BASE_URL=
