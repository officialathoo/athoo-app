# ============================================================
# ATHOO — API Server Environment Variables
# Copy this file to .env and fill in the secrets marked below.
# NEVER commit a .env file with real secrets to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Get from: Replit → Secrets → DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/athoo

# ── Security ─────────────────────────────────────────────────
# Get from: Replit → Secrets → SESSION_SECRET
SESSION_SECRET=your-session-secret-min-64-chars
# Optional — leave blank to reuse SESSION_SECRET
JWT_SECRET=

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Allowed CORS origins — comma-separated, or * for all (dev only)
# Production example: https://admin.athoo.pk,https://app.athoo.pk
CORS_ORIGIN=*

# ── Email / SMTP (Gmail) ──────────────────────────────────────
# When SMTP_PASS is not set, OTP codes are logged to console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=official.athoo@gmail.com
# Get from: Replit → Secrets → SMTP_PASS
SMTP_PASS=your-gmail-app-password
SMTP_FROM=ATHOO <official.athoo@gmail.com>

# ── Cloudinary (File Storage) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=da2ayrh4l
# Get from: Replit → Secrets → CLOUDINARY_API_KEY
CLOUDINARY_API_KEY=your-cloudinary-api-key
# Get from: Replit → Secrets → CLOUDINARY_API_SECRET
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Expo Push Notifications ───────────────────────────────────
# Get from: Replit → Secrets → EXPO_ACCESS_TOKEN
EXPO_ACCESS_TOKEN=your-expo-access-token

# ── WhatsApp OTP (optional) ───────────────────────────────────
# Leave blank — falls back to email OTP when not configured
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
