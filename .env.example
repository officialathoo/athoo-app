# ============================================================
# ATHOO — Root Environment Variables Reference
# This is the master reference for the API server.
# Each artifact also has its own .env.example inside its folder.
#
# Copy relevant sections to each artifact's .env file.
# NEVER commit a .env file with real secrets to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Get from: Replit → Secrets → DATABASE_URL  (auto-provisioned on Replit)
# Local: postgresql://postgres:password@localhost:5432/athoo
DATABASE_URL=postgresql://user:password@host:5432/athoo

# ── Security ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Get from: Replit → Secrets → SESSION_SECRET
SESSION_SECRET=your-session-secret-min-64-random-chars
JWT_SECRET=

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
CORS_ORIGIN=*

# ── Email / SMTP (Gmail) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=official.athoo@gmail.com
# Get from: Replit → Secrets → SMTP_PASS
SMTP_PASS=your-gmail-app-password
SMTP_FROM=ATHOO <official.athoo@gmail.com>

# ── Cloudinary (File Storage) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=da2ayrh4l
# Get from: Replit → Secrets → CLOUDINARY_API_KEY
CLOUDINARY_API_KEY=your-cloudinary-api-key
# Get from: Replit → Secrets → CLOUDINARY_API_SECRET
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Google Maps ───────────────────────────────────────────────
# Enabled APIs needed: Maps SDK Android/iOS, Places API, Geocoding API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Expo / Mobile ─────────────────────────────────────────────
# Get from: expo.dev → your project → settings → Project ID
EXPO_PUBLIC_PROJECT_ID=your-expo-project-uuid
# Get from: Replit → Secrets → EXPO_ACCESS_TOKEN
EXPO_ACCESS_TOKEN=your-expo-access-token
EXPO_PUBLIC_DISABLE_PUSH=false

# ── WhatsApp OTP (optional) ───────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Admin Panel ───────────────────────────────────────────────
# Only needed if admin panel is on a different domain than the API
VITE_API_BASE_URL=
